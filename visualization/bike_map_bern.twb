      <aliases enabled='yes' />
      <column caption='Date' datatype='date' name='[Calculation_1777089419636737]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE([last_reported])' />
      </column>
      <column caption='Last Reported' datatype='string' name='[Calculation_1777089420390403]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='RIGHT(&quot;00&quot; + STR(DATEPART(&apos;hour&apos;, [last_reported])),2)&#13;&#10;+ &quot;:&quot; +&#13;&#10;RIGHT(&quot;00&quot; + STR(DATEPART(&apos;minute&apos;, [last_reported])),2)&#13;&#10;+ &quot;:&quot; +&#13;&#10;RIGHT(&quot;00&quot; + STR(DATEPART(&apos;second&apos;, [last_reported])),2)' />
      </column>
      <column caption='Station Info' datatype='string' name='[Calculation_1777089423036420]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STR([station_id]) + &quot; - &quot; + [station_name]' />
      </column>
      <column caption='Weekday' datatype='string' name='[Calculation_1777089439285253]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [Calculation_1777089419636737])' />
      </column>
      <column caption='Hour of Day' datatype='integer' name='[Calculation_1777089440346118]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, [datetime])' />
      </column>
      <column caption='Week Type' datatype='string' name='[Calculation_1777089445068808]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1777089439285253] = &quot;Saturday&quot;&#13;&#10;OR [Calculation_1777089439285253] = &quot;Sunday&quot;&#13;&#10;THEN &quot;Weekend&quot;&#13;&#10;&#13;&#10;ELSE &quot;Weekday&quot;&#13;&#10;END' />
      </column>
      <column caption='Turnover' datatype='integer' name='[Calculation_1777089448529929]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([total_bikes]) - MIN([total_bikes])' />
      </column>
      <column caption='Rush Hour' datatype='string' name='[Calculation_1777089451155466]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1777089440346118] &gt;= 7&#13;&#10;AND [Calculation_1777089440346118] &lt; 9&#13;&#10;THEN &quot;Morning Rush&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_1777089440346118] &gt;= 16&#13;&#10;AND [Calculation_1777089440346118]&lt;= 18&#13;&#10;THEN &quot;Evening Rush&quot;&#13;&#10;&#13;&#10;ELSE &quot;Outside Rush Hour&quot;&#13;&#10;END' />
      </column>
      <column caption='Rush Ratio' datatype='real' name='[Calculation_1777089452199947]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;IF [Calculation_1777089451155466] = &quot;Rush Hour&quot;&#13;&#10;THEN [total_bikes]&#13;&#10;END&#13;&#10;)&#13;&#10;/&#13;&#10;AVG(&#13;&#10;IF [Calculation_1777089451155466] = &quot;Outside Rush Hour&quot;&#13;&#10;THEN [total_bikes]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Average Rush Hour Bikes' datatype='real' name='[Calculation_1777089453781004]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;IF [Calculation_1777089451155466] = &quot;Morning Rush&quot;&#13;&#10;OR [Calculation_1777089451155466] = &quot;Evening Rush&quot;&#13;&#10;THEN [total_bikes]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Average Non Rush Bikes' datatype='real' name='[Calculation_1777089453862925]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;IF [Calculation_1777089451155466] = &quot;Outside Rush Hour&quot;&#13;&#10;THEN [total_bikes]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Rush Ratioo' datatype='real' name='[Calculation_1777089454018574]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1777089453781004]/[Calculation_1777089453862925]' />
      </column>
      <column caption='final_bike_table.csv' datatype='table' name='[__tableau_internal_object_id__].[final_bike_table.csv_C2389F6D16CA4253AF8F6099E1AA0FE5]' role='measure' type='quantitative' />
