      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.00fily51rzxlgt103web316sntsz].[avg:ebikes:qk]&quot;' value='E-Bikes' />
          <alias key='&quot;[federated.00fily51rzxlgt103web316sntsz].[avg:mbikes:qk]&quot;' value='Regular Bikes' />
        </aliases>
      </column>
      <column caption='Last Reported' datatype='string' name='[Calculation_0877419354042369]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='RIGHT(&quot;00&quot; + STR(DATEPART(&apos;hour&apos;, [last_reported])),2)&#13;&#10;+ &quot;:&quot; +&#13;&#10;RIGHT(&quot;00&quot; + STR(DATEPART(&apos;minute&apos;, [last_reported])),2)&#13;&#10;+ &quot;:&quot; +&#13;&#10;RIGHT(&quot;00&quot; + STR(DATEPART(&apos;second&apos;, [last_reported])),2)' />
      </column>
      <column caption='Date' datatype='date' name='[Calculation_0877419354353666]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE([last_reported])' />
      </column>
      <column caption='Estimated Capacity' datatype='integer' name='[Calculation_0877419355389956]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [station_name] : MAX([total_bikes]) }' />
      </column>
      <column caption='Estimated Utilization Rate' datatype='real' default-format='p0.00%' name='[Calculation_0877419355512837]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([total_bikes]) / MAX([Calculation_0877419355389956])' />
      </column>
      <column caption='Weekday' datatype='string' name='[Calculation_0877419359850502]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [Calculation_0877419354353666])' />
      </column>
      <column aggregation='Sum' caption='Hour of Day' datatype='integer' name='[Calculation_0877419359993863]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, [datetime])' />
      </column>
      <column caption='Rush Hour' datatype='string' name='[Calculation_0877419362926600]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0877419359993863] &gt;= 7&#13;&#10;AND [Calculation_0877419359993863] &lt; 9&#13;&#10;THEN &quot;Morning Rush&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_0877419359993863] &gt;= 16&#13;&#10;AND [Calculation_0877419359993863]&lt;= 18&#13;&#10;THEN &quot;Evening Rush&quot;&#13;&#10;&#13;&#10;ELSE &quot;Outside Rush Hour&quot;&#13;&#10;END' />
      </column>
