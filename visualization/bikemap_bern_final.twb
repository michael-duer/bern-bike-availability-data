    <worksheet name='Most Affected Stations'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#2a5783' fontname='Tableau Bold' fontsize='10'>Top 5 Stations Most Affected by Rush Hours</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='bike_availability_bern' name='federated.00fily51rzxlgt103web316sntsz' />
          </datasources>
          <datasource-dependencies datasource='federated.00fily51rzxlgt103web316sntsz'>
            <column caption='Date' datatype='date' name='[Calculation_0877419354353666]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATE([last_reported])' />
            </column>
            <column aggregation='Sum' caption='Hour of Day' datatype='integer' name='[Calculation_0877419359993863]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, [datetime])' />
            </column>
            <column caption='Rush Hour' datatype='string' name='[Calculation_0877419362926600]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0877419359993863] &gt;= 7&#13;&#10;AND [Calculation_0877419359993863] &lt; 9&#13;&#10;THEN &quot;Morning Rush&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_0877419359993863] &gt;= 16&#13;&#10;AND [Calculation_0877419359993863]&lt;= 18&#13;&#10;THEN &quot;Evening Rush&quot;&#13;&#10;&#13;&#10;ELSE &quot;Outside Rush Hour&quot;&#13;&#10;END' />
            </column>
            <column caption='Datetime' datatype='datetime' name='[datetime]' role='dimension' type='ordinal' />
            <column caption='Last Reported_date' datatype='datetime' name='[last_reported]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_0877419354353666]' derivation='MDY' name='[md:Calculation_0877419354353666:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Calculation_0877419359993863]' derivation='None' name='[none:Calculation_0877419359993863:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Calculation_0877419362926600]' derivation='None' name='[none:Calculation_0877419362926600:nk]' pivot='key' type='nominal' />
            <column-instance column='[station_name]' derivation='None' name='[none:station_name:nk]' pivot='key' type='nominal' />
            <column caption='Station Name' datatype='string' name='[station_name]' role='dimension' type='nominal' />
            <column-instance column='[turnover]' derivation='Sum' name='[sum:turnover:qk]' pivot='key' type='quantitative' />
            <column caption='Turnover' datatype='integer' name='[turnover]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.00fily51rzxlgt103web316sntsz].[none:Calculation_0877419359993863:ok]' filter-group='3'>
            <groupfilter function='level-members' level='[none:Calculation_0877419359993863:ok]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.00fily51rzxlgt103web316sntsz].[none:Calculation_0877419362926600:nk]' context='true'>
            <groupfilter count='5' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='COUNT([turnover])' function='order' user:ui-marker='order'>
                <groupfilter function='except' user:ui-domain='database' user:ui-enumeration='exclusive' user:ui-marker='enumerate'>
                  <groupfilter function='level-members' level='[none:Calculation_0877419362926600:nk]' />
                  <groupfilter function='member' level='[none:Calculation_0877419362926600:nk]' member='&quot;Outside Rush Hour&quot;' />
                </groupfilter>
              </groupfilter>
            </groupfilter>
          </filter>
          <filter class='categorical' column='[federated.00fily51rzxlgt103web316sntsz].[none:station_name:nk]'>
            <groupfilter count='5' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='SUM([turnover])' function='order' user:ui-marker='order'>
                <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
                  <groupfilter function='member' level='[none:station_name:nk]' member='&quot;Aarebad Muri - Bern - Muri&quot;' />
                  <groupfilter function='member' level='[none:station_name:nk]' member='&quot;Abendstrasse - Bern&quot;' />
                  <groupfilter function='member' level='[none:station_name:nk]' member='&quot;Adlerweg - Köniz  - Bern&quot;' />
                  <groupfilter function='member' level='[none:station_name:nk]' member='&quot;Allmendstrasse - Bern&quot;' />
                  <groupfilter function='member' level='[none:station_name:nk]' member='&quot;Altenbergstrasse - Bern&quot;' />
                  <groupfilter function='member' level='[none:station_name:nk]' member='&quot;Anshelmstrasse - Bern&quot;' />
